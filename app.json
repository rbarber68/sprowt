{
  "expo": {
    "name": "SproutPal",
    "slug": "sprowt",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sprowt",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#EAF3DE"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mlwerks.sprowt"
    },
    "android": {
      "package": "com.mlwerks.sprowt",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#EAF3DE"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "POST_NOTIFICATIONS",
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "SCHEDULE_EXACT_ALARM",
        "VIBRATE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-notifications",
        {
          "color": "#3B6D11"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "SproutPal needs camera access to capture sprout photos."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "eac9d58d-da1c-4d67-b55c-c0d2603580ea"
      }
    }
  }
}
